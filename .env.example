# postgresql connection string, should match the values specified in your credentials
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@localhost:5432/POSTGRES_DB

# postgresql credentials , this isused by docker-compose to create the database
POSTGRES_PASSWORD=postgres
POSTGRES_DB=credpal
POSTGRES_USER=postgres

# redis connection string, the redis service provided via docker
REDIS_URL=redis://localhost:6379

# cookie domain, use localhost for local development
DOMAIN=localhost

# api base URL
BASE_URL=http://localhost:3000

# frontend URL for CORS
FRONTEND_URL=http://localhost:3001

# RS256 key pair for JWT signing
# Generate with:
#   openssl genrsa -out private.key 2048
#   openssl rsa -in private.key -pubout -out public.key
# Then paste the contents below (keep the -----BEGIN/END----- lines)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Service name for logging
SERVICE_NAME=credpal-api

# logging level: debug | info | warn | error
LOG_LEVEL=info

# environment
NODE_ENV=development

# exchangeRate-API key, get one free at https://www.exchangerate-api.com
FX_API_KEY=your_exchangerate_api_key
FX_API_URL=https://v6.exchangerate-api.com/v6

# resend API key, get one at https://resend.com
# Note: if mail delivery fails, OTP codes are logged to console in non-production mode  and debug mode
RESEND_API_KEY=your_resend_api_key

# sender email address, must be a verified domain in Resend
MAIL_FROM=noreply@yourdomain.com